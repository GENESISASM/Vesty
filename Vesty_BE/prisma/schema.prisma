generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  finances   Finance[]
  stocks     Stock[]

  @@map("users")
}

model Finance {
  id          String   @id @default(uuid())
  user_id     String
  type        String   // "income" | "expense"
  amount      Decimal  @db.Decimal(15, 2)
  category    String
  description String?
  date        DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id])

  @@map("finances")
}

model Stock {
  id            String   @id @default(uuid())
  user_id       String
  item_name     String
  category      String?
  current_stock Int      @default(0)
  unit          String   // pcs, kg, liter, etc
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User           @relation(fields: [user_id], references: [id])
  history       StockHistory[]

  @@map("stocks")
}

model StockHistory {
  id          String   @id @default(uuid())
  stock_id    String
  type        String   // "in" | "out"
  quantity    Int
  notes       String?
  date        DateTime
  created_at  DateTime @default(now())

  stock       Stock    @relation(fields: [stock_id], references: [id])

  @@map("stock_histories")
}