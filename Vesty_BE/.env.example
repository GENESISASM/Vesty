# --- DATABASE CONFIGURATION ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Jika menggunakan Supabase, ambil Connection String (Transaction mode/Session mode) dari dashboard.
DATABASE_URL="postgresql://postgres:your_password@db.xxxxxxx.supabase.co:5432/postgres"

# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development

# --- AUTHENTICATION (JWT token or anything) ---
# Gunakan string acak yang panjang untuk secret
JWT_SECRET="your_jwt_secret_key_random_string"
JWT_EXPIRES_IN="1d"

# --- CORS (Cross-Origin Resource Sharing) Optional ---
# URL frontend agar bisa berinteraksi dengan API
FRONTEND_URL="http://localhost:3000"